// Prisma schema — Kino bot
// DB: PostgreSQL

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== FOYDALANUVCHILAR =====================
model User {
  id                BigInt   @id
  firstName         String?
  username          String?
  region            String?
  referredById      BigInt?  // kim taklif qilgan
  referralConfirmed Boolean  @default(false) // obunadan keyin tasdiqlanadi
  isBlocked         Boolean  @default(false)
  isAdmin           Boolean  @default(false)
  permissions       String?  // ruxsat etilgan bo'limlar (vergul bilan); null = hammasi
  channelLimit      Int?     // majburiy obunaga qo'sha oladigan max kanal; null = cheksiz
  premiumUntil      DateTime? // premium tugash vaqti (null/o'tgan = premium emas)
  requestCount      Int      @default(0)  // bepul kino so'rovlari hisobi
  firstRequestAt    DateTime? // birinchi so'rov vaqti (vaqt cheklovi uchun)
  aiRequestCount    Int      @default(0)  // bugungi AI so'rovlari hisobi
  aiRequestDay      String?  // "YYYY-MM-DD" — kun o'zgarsa aiRequestCount reset
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([referredById])
  @@map("users")
}

// ===================== PREMIUM TARIFLAR =====================
model Tariff {
  id         Int     @id @default(autoincrement())
  label      String  // masalan "1 oy"
  days       Int     // premium davomiyligi (kun)
  price      Int     // narx (so'm)
  starsPrice Int?    // Telegram Stars narxi (null = Stars orqali sotib olib bo'lmaydi)
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  @@map("tariffs")
}

// ===================== PREMIUM TO'LOVLARI (qo'lda tasdiq) =====================
model Payment {
  id           Int       @id @default(autoincrement())
  userId       BigInt
  tariffId     Int
  tariffLabel  String    // snapshot (tarif o'zgarsa tarix buzilmasin)
  days         Int       // snapshot
  amount       Int       // snapshot
  method       String    @default("karta") // karta | ton | stars
  status       String    @default("pending") // pending | approved | rejected
  proofFileId  String?   // chek/screenshot file_id
  createdAt    DateTime  @default(now())
  reviewedById BigInt?
  reviewedAt   DateTime?

  @@index([status])
  @@index([userId])
  @@map("payments")
}

// ===================== FUNNEL (SO'ROVNOMA) =====================
model Survey {
  id             Int      @id @default(autoincrement())
  title          String
  question       String
  isRegionSurvey Boolean  @default(false)
  sentCount      Int      @default(0)
  createdAt      DateTime @default(now())

  options   SurveyOption[]
  responses SurveyResponse[]

  @@map("surveys")
}

model SurveyOption {
  id        Int    @id @default(autoincrement())
  surveyId  Int
  text      String
  sortOrder Int    @default(0)

  survey    Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  responses SurveyResponse[]

  @@map("survey_options")
}

model SurveyResponse {
  id       Int      @id @default(autoincrement())
  surveyId Int
  optionId Int
  userId   BigInt
  date     DateTime @default(now())

  survey Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  option SurveyOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
  @@map("survey_responses")
}

// ===================== BROADCAST TARIXI =====================
model Broadcast {
  id          Int      @id @default(autoincrement())
  targetType  String   @default("all")
  targetExtra String?
  sentCount   Int      @default(0)
  failCount   Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("broadcasts")
}

// ===================== MAJBURIY OBUNA KANALLARI =====================
enum ChannelType {
  PUBLIC    // Ommaviy — @username bor
  PRIVATE   // Maxfiy — havola orqali
  REQUEST   // So'rovli — apply to join
  INSTAGRAM // Instagram profil — API tekshiruvi yo'q
}

model Channel {
  id          Int         @id @default(autoincrement())
  chatId      BigInt      @unique // Telegram chat id (-100...) yoki 0 Instagram uchun
  title       String
  username    String?
  inviteLink  String?     // PRIVATE/REQUEST uchun havola; INSTAGRAM uchun profil URL
  type        ChannelType @default(PUBLIC)
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  buttonLabel String?     // Obuna sahifasida ko'rsatiladigan maxsus yorliq
  createdAt   DateTime    @default(now())

  joinRequests JoinRequest[]

  @@map("channels")
}

// ===================== QO'SHILISH SO'ROVLARI (REQUEST kanallari) =====================
model JoinRequest {
  id        Int      @id @default(autoincrement())
  channelId BigInt
  userId    BigInt
  firstName String?
  username  String?
  status    String   @default("pending") // pending | approved | declined
  date      DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [chatId], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId, date])
  @@map("join_requests")
}

// ===================== KANAL QO'SHILISH/CHIQISH HODISALARI (statistika) =====================
model ChannelEvent {
  id        Int      @id @default(autoincrement())
  channelId BigInt
  userId    BigInt
  type      String   @default("join") // join | leave
  date      DateTime @default(now())

  @@index([channelId, date])
  @@map("channel_events")
}

// ===================== MANBA KANALLAR (avto-indekslash) =====================
model SourceChannel {
  id      Int      @id @default(autoincrement())
  chatId  BigInt   @unique
  title   String
  addedAt DateTime @default(now())

  @@map("source_channels")
}

// ===================== AI SARF-HISOBI (kunlik, provayder+model bo'yicha) =====================
model AiUsage {
  id       Int      @id @default(autoincrement())
  provider String
  model    String
  day      String   // "YYYY-MM-DD" (UTC)
  requests Int      @default(0)
  tokens   Int      @default(0)

  @@unique([provider, model, day])
  @@map("ai_usage")
}

// ===================== KINO =====================
model Movie {
  id          Int      @id @default(autoincrement())
  code        Int      @unique
  title       String
  caption     String?
  fileId      String
  baseMsgId   Int?
  year        Int?
  genre       String?
  quality     String?
  language    String?
  duration    Int?     // sekundlarda
  shortFileId String?  // qisqa (treyler) video file_id
  shortMsgId  Int?     // kino kanaldagi qisqa video xabar id
  buttonText  String?
  buttonUrl   String?
  buttonStyle String   @default("primary")
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([title])
  @@map("movies")
}

// ===================== SERIAL =====================
model Serial {
  id          Int      @id @default(autoincrement())
  code        Int      @unique
  title       String
  caption     String?
  posterId    String?
  year        Int?
  genre       String?
  buttonText  String?
  buttonUrl   String?
  buttonStyle String   @default("primary")
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seasons Season[]

  @@index([title])
  @@map("serials")
}

model Season {
  id       Int     @id @default(autoincrement())
  serialId Int
  number   Int
  title    String?

  serial   Serial    @relation(fields: [serialId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([serialId, number])
  @@map("seasons")
}

model Episode {
  id        Int      @id @default(autoincrement())
  seasonId  Int
  number    Int
  title     String?
  fileId    String
  baseMsgId Int?
  createdAt DateTime @default(now())

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
  @@map("episodes")
}

// ===================== SOZLAMALAR =====================
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}
